{
  "_description": "Payloads de prueba para simular mensajes entrantes de WhatsApp. Usar con curl o Postman contra POST /api/whatsapp/webhook",

  "scenario_01_client_text_dedicated_number": {
    "_desc": "Cliente envia texto al numero dedicado de Notaria 14",
    "_phone": "Juan Perez (vinculado, caso compraventa)",
    "entry": [{
      "changes": [{
        "value": {
          "messaging_product": "whatsapp",
          "metadata": {"phone_number_id": "DEDICATED_N14_TEST_001"},
          "contacts": [{"wa_id": "5215512345678", "profile": {"name": "Juan Perez"}}],
          "messages": [{
            "from": "5215512345678",
            "id": "wamid_live_001",
            "type": "text",
            "timestamp": "1709078000",
            "text": {"body": "Hola, ya tengo todos los documentos listos"}
          }]
        }
      }]
    }]
  },

